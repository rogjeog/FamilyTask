# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=familytask
POSTGRES_PASSWORD=change_me_local_dev
POSTGRES_DB=familytask

# ─── Backend ──────────────────────────────────────────────────────────────────
# Uses "postgres" as hostname (Docker service name), not localhost
DATABASE_URL=postgresql://familytask:change_me_local_dev@postgres:5432/familytask?schema=public
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=change_me_minimum_32_chars_access_secret_dev
JWT_REFRESH_SECRET=change_me_minimum_32_chars_refresh_secret_dev
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
CORS_ORIGINS=http://localhost:3001
NODE_ENV=development
PORT=3000
APP_NAME=FamilyTask
COOKIE_DOMAIN=

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Uses localhost (browser → SSH tunnel → VPS), not the Docker service name
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_APP_NAME=FamilyTask
