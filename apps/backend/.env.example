# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=FamilyTask

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://familytask:password@localhost:5432/familytask

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-in-production-must-be-at-least-32-chars!!
JWT_REFRESH_SECRET=change-me-in-production-must-be-at-least-32-chars!!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001

# ─── Cookie ───────────────────────────────────────────────────────────────────
# Leave empty for localhost; set to your domain in production (e.g. .btsinfo.nc)
COOKIE_DOMAIN=
